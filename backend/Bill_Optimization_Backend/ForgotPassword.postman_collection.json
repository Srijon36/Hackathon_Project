{
  "info": {
    "name": "Forgot Password API",
    "_postman_id": "fp-api-collection-001",
    "description": "3-step Forgot Password flow: Send OTP → Verify OTP → Reset Password",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "resetToken",
      "value": "",
      "type": "string",
      "description": "Auto-populated after Verify OTP request succeeds"
    }
  ],
  "item": [
    {
      "name": "Step 1 — Send OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/forgot-password/send-otp",
          "host": ["{{baseUrl}}"],
          "path": ["api", "forgot-password", "send-otp"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "description": "Sends a 6-digit OTP to the provided email address. OTP is valid for 10 minutes."
      },
      "response": [
        {
          "name": "Success",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"message\": \"OTP sent to your email address. It is valid for 10 minutes.\"\n}"
        },
        {
          "name": "Missing Email",
          "status": "Bad Request",
          "code": 400,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": false,\n  \"message\": \"Email is required.\"\n}"
        }
      ]
    },
    {
      "name": "Step 2 — Verify OTP",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json.resetToken) {",
              "  pm.collectionVariables.set(\"resetToken\", json.resetToken);",
              "  console.log(\"✅ resetToken saved:\", json.resetToken);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/forgot-password/verify-otp",
          "host": ["{{baseUrl}}"],
          "path": ["api", "forgot-password", "verify-otp"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"otp\": \"123456\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "description": "Verifies the 6-digit OTP. On success, returns a JWT resetToken (valid 15 min) which is auto-saved to the collection variable."
      },
      "response": [
        {
          "name": "Success",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"message\": \"OTP verified. Use the reset token to set your new password.\",\n  \"resetToken\": \"<jwt_token_here>\"\n}"
        },
        {
          "name": "Wrong OTP",
          "status": "Bad Request",
          "code": 400,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": false,\n  \"message\": \"Incorrect OTP.\"\n}"
        },
        {
          "name": "Expired OTP",
          "status": "Bad Request",
          "code": 400,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": false,\n  \"message\": \"OTP has expired. Please request a new one.\"\n}"
        }
      ]
    },
    {
      "name": "Step 3 — Reset Password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/forgot-password/reset-password",
          "host": ["{{baseUrl}}"],
          "path": ["api", "forgot-password", "reset-password"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"resetToken\": \"{{resetToken}}\",\n  \"newPassword\": \"MyNewPassword123\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "description": "Resets the user's password. Uses the resetToken saved automatically from Step 2. Password must be at least 6 characters."
      },
      "response": [
        {
          "name": "Success",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"message\": \"Password reset successfully. You can now log in with your new password.\"\n}"
        },
        {
          "name": "Invalid Token",
          "status": "Bad Request",
          "code": 400,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": false,\n  \"message\": \"Invalid or expired reset token.\"\n}"
        },
        {
          "name": "Short Password",
          "status": "Bad Request",
          "code": 400,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": false,\n  \"message\": \"Password must be at least 6 characters.\"\n}"
        }
      ]
    }
  ]
}
